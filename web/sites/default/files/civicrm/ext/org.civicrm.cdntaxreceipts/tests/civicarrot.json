{
  "singlePR": {
    "include": [
      {
        "php-versions": "CIVICARROT_PHP_SENSIBLE",
        "drupal": "^10",
        "civicrm": "dev-master",
        "phpunit-xml": "phpunit9.xml.dist",
        "phpunit-mink-xml": "phpunit9.mink.xml.dist"
      },
      {
        "php-versions": "8.3",
        "drupal": "CIVICARROT_DRUPAL_PRIOR",
        "civicrm": "dev-master",
        "phpunit-xml": "phpunit10.xml.dist",
        "phpunit-mink-xml": "phpunit10.mink.xml.dist"
      }
    ]
  },
  "periodic": {
    "MyDaily": {
      "cronSpec": "30 3 * * *",
      "testType": "all",
      "matrix": {
        "include": [
          {
            "php-versions": "8.3",
            "drupal": "CIVICARROT_DRUPAL_PRIOR",
            "civicrm": "dev-master",
            "phpunit-xml": "phpunit10.xml.dist",
            "phpunit-mink-xml": "phpunit10.mink.xml.dist"
          },
          {
            "php-versions": "8.3",
            "drupal": "^10",
            "civicrm": "CIVICARROT_CIVI_RELEASECANDIDATE",
            "phpunit-xml": "phpunit9.xml.dist",
            "phpunit-mink-xml": "phpunit9.mink.xml.dist"
          },
          {
            "php-versions": "CIVICARROT_PHP_SENSIBLE",
            "drupal": "^10",
            "civicrm": "CIVICARROT_CIVI_LATEST",
            "phpunit-xml": "phpunit9.xml.dist",
            "phpunit-mink-xml": "phpunit9.mink.xml.dist"
          },
          {
            "php-versions": "8.2",
            "drupal": "^10",
            "civicrm": "6.10.*",
            "phpunit-xml": "phpunit9.xml.dist",
            "phpunit-mink-xml": "phpunit9.mink.xml.dist"
          }
        ]
      }
    }
  }
}
